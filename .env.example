# UNAGI Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Configuration (REQUIRED)
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=models/gemini-2.5-flash

# ============================================
# Git Configuration (OPTIONAL)
# ============================================
GIT_AUTHOR_NAME=Unagi
GIT_AUTHOR_EMAIL=unagi@local
GIT_REMOTE_URL=
GIT_REMOTE_TOKEN=

# ============================================
# Intelligence System API Keys (OPTIONAL)
# ============================================
# USDA FoodData Central API
# Get your key from: https://fdc.nal.usda.gov/api-key-signup.html
# Leave empty to skip USDA enrichment
USDA_API_KEY=

# Open Food Facts User Agent
# Format: AppName/Version (contact@email.com)
OPENFOODFACTS_USER_AGENT=Unagi/1.0

# ============================================
# Notes
# ============================================
# - LLM_API_KEY is required for the agent to work
# - USDA_API_KEY is optional; system works without it
# - Intelligence features work without API keys (uses local data + LLM)
# - Git configuration is optional; can be set during onboarding